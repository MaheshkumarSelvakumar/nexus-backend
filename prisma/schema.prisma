generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Quest {
  id         Int      @id @default(autoincrement())
  title      String
  subject    String
  difficulty String
  status     String   @default("todo")
  createdAt  DateTime @default(now())
}